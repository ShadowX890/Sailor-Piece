-- Auto Slime Piece Loop
local function autoSlimePieceLoop()
    while autoSlimePieceRunning do
        for _, loc in ipairs(slimePieceLocations) do
            if not autoSlimePieceRunning then break end

            if not hrp then
                local char = player.Character
                if char then hrp = char:FindFirstChild("HumanoidRootPart") end
            end
            if not hrp then
                RunService.Heartbeat:Wait()
                continue
            end

            -- วาร์ปไปที่ตำแหน่งกลางของเกาะ (หรือจุดที่กำหนด)
            hrp.CFrame = CFrame.new(loc.pos) * CFrame.new(0, 5, 0)  -- ยกสูงขึ้นเล็กน้อย
            task.wait(2)  -- รอให้โฟลเดอร์และโมเดลภายในโหลด

            -- หา SlimePuzzlePiece ทั่ว workspace
            local piece = nil
            if loc.name == "Final Spot" then
                -- สำหรับตำแหน่งสุดท้าย ให้หาชิ้นส่วนที่ใกล้ตำแหน่งนี้ที่สุด
                local minDist = math.huge
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj.Name == "SlimePuzzlePiece" and obj:IsA("BasePart") then
                        local dist = (obj.Position - loc.pos).Magnitude
                        if dist < minDist then
                            minDist = dist
                            piece = obj
                        end
                    end
                end
            else
                -- สำหรับเกาะทั่วไป หาชิ้นส่วนใน workspace (เพราะอาจอยู่ในโมเดลใดก็ได้ในโฟลเดอร์)
                piece = workspace:FindFirstChild("SlimePuzzlePiece", true)
            end

            if piece and piece:IsA("BasePart") then
                hrp.CFrame = piece.CFrame * CFrame.new(0, 2, 0)  -- ยืนบนชิ้นส่วน
                task.wait(0.8)
                VirtualInput:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                task.wait(0.8)
                VirtualInput:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                -- อาจเพิ่ม task.wait(1) เพื่อให้เกมบันทึกการเก็บ
            else
                WindUI:Notify({
                    Title = "Slime Piece",
                    Content = "Not found at " .. (loc.name or "final spot"),
                    Duration = 1,
                    Icon = "alert",
                })
            end

            task.wait(1)  -- หน่วงก่อนไปตำแหน่งถัดไป
        end
        -- วนซ้ำเรื่อย ๆ
    end
end

