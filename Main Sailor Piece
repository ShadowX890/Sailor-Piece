-- ฟังก์ชันดึงรายชื่อ NPC จาก workspace.ServiceNPCs
local function getNPCNames()
    local names = {}
    local serviceNPCs = workspace:FindFirstChild("ServiceNPCs")
    if serviceNPCs then
        for _, child in ipairs(serviceNPCs:GetChildren()) do
            table.insert(names, child.Name)
        end
    end
    table.sort(names)  -- เรียงตามตัวอักษร
    return names
end

