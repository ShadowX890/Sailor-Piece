local function getSpawnCFrame(level)
    for _, mode in ipairs(modes) do
        if level >= mode.min and level <= mode.max then
            local pos = spawnPositions[mode.min]
            if pos and pos.Magnitude > 0 then
                return CFrame.new(pos) * CFrame.new(0, 3, 0)
            end
            break
        end
    end
    local spawnPoint = workspace:FindFirstChild("StarterIsland") and workspace.StarterIsland:FindFirstChild("SpawnPointCrystal_Starter")
    if spawnPoint then
        return spawnPoint.CFrame * CFrame.new(0, 3, 0)
    end
    return CFrame.new(hrp.Position.X, floatHeight, hrp.Position.Z)
end

