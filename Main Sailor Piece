-- Dropdown เลือก NPC
npcDropdown = TPNPCTab:Dropdown({
    Title = "Select NPC",
    Desc = "Select an NPC to teleport to",
    Values = getNPCNames(),
    Value = "",
    Callback = function(option)
        if option == "" then return end

        -- ค้นหา NPC ใน workspace.ServiceNPCs
        local npc = workspace:FindFirstChild("ServiceNPCs") and workspace.ServiceNPCs:FindFirstChild(option)
        if not npc then
            WindUI:Notify({
                Title = "Error",
                Content = "ไม่พบ NPC: " .. option,
                Duration = 2,
                Icon = "alert",
            })
            return
        end

        -- หา HumanoidRootPart ของผู้เล่น
        if not hrp then
            local char = player.Character
            if char then
                hrp = char:FindFirstChild("HumanoidRootPart")
            end
        end
        if not hrp then
            WindUI:Notify({
                Title = "Error",
                Content = "ไม่พบ HumanoidRootPart",
                Duration = 2,
                Icon = "alert",
            })
            return
        end

        -- ได้ตำแหน่งของ NPC (ใช้ GetPivot() รองรับทั้ง Model และ BasePart)
        local targetCF = npc:GetPivot()
        hrp.CFrame = targetCF * CFrame.new(0, 3, 0)  -- ยกสูงขึ้นเล็กน้อย

        WindUI:Notify({
            Title = "Teleported",
            Content = "TP to " .. option,
            Duration = 2,
            Icon = "check",
        })
    end
})

