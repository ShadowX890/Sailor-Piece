local function autoSummonLoop()
    print("autoSummonLoop started")
    local success, err = pcall(function()
        while autoSummonRunning do
            if not hrp then
                local char = player.Character
                if char then
                    hrp = char:FindFirstChild("HumanoidRootPart")
                end
                if not hrp then
                    RunService.Heartbeat:Wait()
                    continue
                end
            end

            local now = tick()
            local bossData = nil
            for _, b in ipairs(summonBossList) do
                if b.name == selectedSummonBoss then
                    bossData = b
                    break
                end
            end

            if not bossData then
                warn("Unknown summon boss:", selectedSummonBoss)
                RunService.Heartbeat:Wait()
                continue
            end

            local bossExists = false
            for _, monster in ipairs(npcFolder:GetChildren()) do
                if monster.Name:find("^" .. selectedSummonBoss) then
                    local humanoid = monster:FindFirstChild("Humanoid")
                    if humanoid and humanoid.Health > 0 then
                        bossExists = true
                        break
                    end
                end
            end

            if not bossExists then
                if now >= lastSummonTime + summonCooldown then
                    if bossData.remoteName == "RequestSpawnStrongestBoss" then
                        hrp.CFrame = CFrame.new(shinjukuSummonPosition) * CFrame.new(0, 3, 0)
                    else
                        hrp.CFrame = CFrame.new(summonPosition) * CFrame.new(0, 3, 0)
                    end
                    task.wait(1)

                    local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild(bossData.remoteName)
                    if remote then
                        if bossData.remoteName == "RequestSpawnRimuru" then
                            local args = { selectedDifficulty }
                            remote:FireServer(unpack(args))
                        elseif bossData.hasDifficulty then
                            local args = { bossData.args[1], selectedDifficulty }
                            remote:FireServer(unpack(args))
                        else
                            local args = bossData.args
                            remote:FireServer(unpack(args))
                        end
                        lastSummonTime = now
                        WindUI:Notify({
                            Title = "Summon",
                            Content = "Summoned " .. bossData.display,
                            Duration = 2,
                            Icon = "info",
                        })
                    else
                        warn(bossData.remoteName .. " remote not found")
                    end
                end
            end

            RunService.Heartbeat:Wait()
        end
    end)
    if not success then
        warn("autoSummonLoop error:", err)
    end
    print("autoSummonLoop ended")
end

