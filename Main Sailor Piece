-- Auto Kill Dungeon Mobs Loop
local function autoKillDungeonMobsLoop()
    while autoKillDungeonMobsRunning do
        if not hrp then
            local char = player.Character
            if char then hrp = char:FindFirstChild("HumanoidRootPart") end
        end
        if not hrp then
            RunService.Heartbeat:Wait()
            continue
        end

        -- 🔁 เพิ่มส่วนนี้: ตรวจสอบและสวมใส่อาวุธที่เลือก
        if selectedWeapon ~= "" then
            local character = player.Character
            if character then
                local toolInHand = character:FindFirstChild(selectedWeapon)
                if not toolInHand then
                    local backpack = player:FindFirstChild("Backpack")
                    if backpack then
                        local tool = backpack:FindFirstChild(selectedWeapon)
                        if tool and tool:IsA("Tool") then
                            tool.Parent = character
                        end
                    end
                end
            end
        end

        -- หา mob จาก npcFolder (workspace.NPCs)
        local target = nil
        for _, mob in ipairs(npcFolder:GetChildren()) do
            local humanoid = mob:FindFirstChild("Humanoid")
            local root = mob:FindFirstChild("HumanoidRootPart")
            if humanoid and humanoid.Health > 0 and root then
                target = mob
                break
            end
        end

        if target then
            -- โจมตี
            local root = target:FindFirstChild("HumanoidRootPart")
            if root then
                local behindPos = root.Position + root.CFrame.LookVector * -attackDistance
                hrp.CFrame = CFrame.lookAt(behindPos, root.Position)
                hrp.Anchored = false

                local now = tick()
                if now >= lastAttackTime + attackCooldown then
                    requestHit:FireServer()
                    lastAttackTime = now
                end

                -- ใช้ skill auto ถ้าเปิด
                for skillName, enabled in pairs(skillToggles) do
                    if enabled then
                        local lastTime = lastSkillPressTime[skillName] or 0
                        if now >= lastTime + skillPressCooldown then
                            local keyCode = getKeyCode(skillName)
                            if keyCode then
                                VirtualInput:SendKeyEvent(true, keyCode, false, game)
                                task.wait(0.05)
                                VirtualInput:SendKeyEvent(false, keyCode, false, game)
                                lastSkillPressTime[skillName] = now
                            end
                        end
                    end
                end
            end
        else
            -- ไม่มี mob: วาร์ปไป respawn point
            hrp.CFrame = CFrame.new(dungeonRespawnPoint) * CFrame.new(0, 3, 0)
            hrp.Anchored = true
            hrp.Velocity = Vector3.zero
            hrp.AssemblyLinearVelocity = Vector3.zero
        end

        RunService.Heartbeat:Wait()
    end
end

