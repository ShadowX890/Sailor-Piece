local function enableNoclip()
    if noclipConnection then return end
    noclipConnection = RunService.Stepped:Connect(function()
        if player.Character then
            for _, v in pairs(player.Character:GetDescendants()) do
                if v:IsA("BasePart") and v.CanCollide then
                    v.CanCollide = false
                end
            end
        end
    end)
end

local function disableNoclip()
    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end
end

local function safelyLand()
    if not hrp then return end
    hrp.CFrame = hrp.CFrame - Vector3.new(0, landHeight, 0)
    hrp.Velocity = Vector3.zero
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.Anchored = false
end

local function updateWeaponDropdown()
    if not weaponDropdown then return end
    local weapons = {}
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                table.insert(weapons, tool.Name)
            end
        end
    end
    local methods = {"Set", "SetValues", "Update", "SetOptions", "Refresh"}
    for _, methodName in ipairs(methods) do
        local method = weaponDropdown[methodName]
        if method then
            local success = pcall(method, weaponDropdown, weapons)
            if success then break end
        end
    end
end

local function setupBackpackListener()
    local backpack = player:WaitForChild("Backpack")
    updateWeaponDropdown()
    backpack.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then updateWeaponDropdown() end
    end)
    backpack.ChildRemoved:Connect(function(child)
        if child:IsA("Tool") then updateWeaponDropdown() end
    end)
end

local function equipWeapon(weaponName)
    if weaponName == "" then return end
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return end
    local tool = backpack:FindFirstChild(weaponName)
    if tool and tool:IsA("Tool") then
        local character = player.Character
        if character then
            tool.Parent = character
        end
    end
end

local function onCharacterAdded(newChar)
    hrp = newChar:WaitForChild("HumanoidRootPart")
    currentTarget = nil

    local humanoid = newChar:WaitForChild("Humanoid")
    if walkSpeedEnabled then
        humanoid.WalkSpeed = customWalkSpeed
    end
    if jumpPowerEnabled then
        humanoid.JumpPower = customJumpPower
    end
    if noclipEnabled then
        enableNoclip()
    end

    if autoFarmRunning or autoMobRunning or autoBossRunning then
        task.wait(1)

        if autoBusoHaki then
            task.wait(0.3)
            local args = { "Toggle" }
            local remote = ReplicatedStorage:FindFirstChild("RemoteEvents") and ReplicatedStorage.RemoteEvents:FindFirstChild("HakiRemote")
            if remote then
                remote:FireServer(unpack(args))
            end
        end
        if autoObservationHaki then
            task.wait(0.3)
            local args = { "Toggle" }
            local remote = ReplicatedStorage:FindFirstChild("RemoteEvents") and ReplicatedStorage.RemoteEvents:FindFirstChild("ObservationHakiRemote")
            if remote then
                remote:FireServer(unpack(args))
            end
        end

        -- เฉพาะ Auto Farm Level เท่านั้นที่ต้องหาเป้าหมายใหม่ที่นี่
        if autoFarmRunning then
            local level = levelValue.Value
            local currentMode = nil
            for _, mode in ipairs(modes) do
                if level >= mode.min and level <= mode.max then
                    currentMode = mode
                    break
                end
            end

            if currentMode then
                local lowestHealth = math.huge
                local bestTarget = nil
                for _, monsterName in ipairs(currentMode.monsters) do
                    local monster = npcFolder:FindFirstChild(monsterName)
                    if monster then
                        local humanoid = monster:FindFirstChild("Humanoid")
                        local monRoot = monster:FindFirstChild("HumanoidRootPart")
                        if humanoid and humanoid.Health > 0 and monRoot then
                            if humanoid.Health < lowestHealth then
                                lowestHealth = humanoid.Health
                                bestTarget = monster
                            end
                        end
                    end
                end
                if bestTarget then
                    currentTarget = bestTarget
                end
            end
        end

        if selectedWeapon ~= "" then
            equipWeapon(selectedWeapon)
        end
    end

    updateWeaponDropdown()
end

player.CharacterAdded:Connect(onCharacterAdded)
