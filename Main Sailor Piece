-- ฟังก์ชัน Priority Loop (รวม Boss และ Mob)
local function autoPriorityLoop()
    print("autoPriorityLoop started")
    local currentSpawnIndex = 1
    local lastWarpTime = 0
    local warpCooldown = 5

    local function getUniqueBossSpawns()
        local unique = {}
        local seen = {}
        for _, boss in ipairs(selectedBosses) do
            local key = string.format("%.3f,%.3f,%.3f", boss.spawnPos.X, boss.spawnPos.Y, boss.spawnPos.Z)
            if not seen[key] then
                seen[key] = true
                table.insert(unique, boss.spawnPos)
            end
        end
        return unique
    end

    local success, err = pcall(function()
        while autoPriorityRunning do
            if not hrp then
                local char = player.Character
                if char then
                    hrp = char:FindFirstChild("HumanoidRootPart")
                end
                if not hrp then
                    RunService.Heartbeat:Wait()
                    continue
                end
            end

            if selectedWeapon ~= "" then
                local character = player.Character
                if character then
                    local toolInHand = character:FindFirstChild(selectedWeapon)
                    if not toolInHand then
                        local backpack = player:FindFirstChild("Backpack")
                        if backpack then
                            local tool = backpack:FindFirstChild(selectedWeapon)
                            if tool and tool:IsA("Tool") then
                                tool.Parent = character
                            end
                        end
                    end
                end
            end

            local now = tick()

            if autoObservationHaki then
                if now >= lastObservationCheck + observationCheckCooldown then
                    local cooldownUI = player.PlayerGui:FindFirstChild("CooldownUI")
                    local inCooldown = false
                    if cooldownUI then
                        local mainFrame = cooldownUI:FindFirstChild("MainFrame")
                        if mainFrame then
                            local obsCooldown = mainFrame:FindFirstChild("Cooldown_ObsHaki_Observation")
                            if obsCooldown then inCooldown = true end
                        end
                    end
                    local dodgeUI = player.PlayerGui:FindFirstChild("DodgeCounterUI")
                    local hakiOn = false
                    if dodgeUI then
                        local mainFrame = dodgeUI:FindFirstChild("MainFrame")
                        if mainFrame and mainFrame.Visible then hakiOn = true end
                    end
                    if not inCooldown and not hakiOn then
                        if now >= lastObservationRemoteTime + minRemoteInterval then
                            local remote = ReplicatedStorage:FindFirstChild("RemoteEvents") and ReplicatedStorage.RemoteEvents:FindFirstChild("ObservationHakiRemote")
                            if remote then
                                pcall(function() remote:FireServer({ "Toggle" }) end)
                                lastObservationRemoteTime = now
                            end
                        end
                    end
                    lastObservationCheck = now
                end
            end

            if autoBossRunning and #selectedBosses > 0 and not currentTarget then
                if now >= lastWarpTime + 1 then
                    local firstBoss = selectedBosses[1]
                    if firstBoss and firstBoss.spawnPos then
                        hrp.CFrame = CFrame.new(firstBoss.spawnPos) * CFrame.new(0, 3, 0)
                        lastWarpTime = now
                    end
                end
            end

            local target = nil
            if autoBossRunning then
                target = findBossTarget()
            end
            if not target and autoMobRunning then
                target = findMobTarget()
            end

            if target then
                currentTarget = target
                currentSpawnIndex = 1
                local monRoot = currentTarget:FindFirstChild("HumanoidRootPart")
                if not monRoot then
                    currentTarget = nil
                    RunService.Heartbeat:Wait()
                    continue
                end
                local behindPos = monRoot.Position + monRoot.CFrame.LookVector * -attackDistance
                hrp.CFrame = CFrame.lookAt(behindPos, monRoot.Position)
                hrp.Anchored = false

                if now >= lastAttackTime + attackCooldown then
                    requestHit:FireServer()
                    lastAttackTime = now
                end

                for skillName, enabled in pairs(skillToggles) do
                    if enabled then
                        local lastTime = lastSkillPressTime[skillName] or 0
                        if now >= lastTime + skillPressCooldown then
                            local keyCode = getKeyCode(skillName)
                            if keyCode then
                                VirtualInput:SendKeyEvent(true, keyCode, false, game)
                                task.wait(0.05)
                                VirtualInput:SendKeyEvent(false, keyCode, false, game)
                                lastSkillPressTime[skillName] = now
                            end
                        end
                    end
                end
            else
                if autoBossRunning and #selectedBosses > 0 then
                    local uniqueSpawn = getUniqueBossSpawns()
                    if #uniqueSpawn > 0 then
                        if now >= lastWarpTime + warpCooldown then
                            local pos = uniqueSpawn[currentSpawnIndex]
                            if pos then
                                hrp.CFrame = CFrame.new(pos) * CFrame.new(0, 3, 0)
                            else
                                hrp.CFrame = getSpawnCFrame(levelValue.Value)
                            end
                            currentSpawnIndex = currentSpawnIndex + 1
                            if currentSpawnIndex > #uniqueSpawn then
                                currentSpawnIndex = 1
                            end
                            lastWarpTime = now
                        end
                        hrp.Anchored = true
                        hrp.Velocity = Vector3.zero
                        hrp.AssemblyLinearVelocity = Vector3.zero
                    else
                        hrp.CFrame = getSpawnCFrame(levelValue.Value)
                        hrp.Anchored = true
                        hrp.Velocity = Vector3.zero
                        hrp.AssemblyLinearVelocity = Vector3.zero
                    end
                elseif autoMobRunning and #selectedMobGroups > 0 then
                    local key = selectedMobGroups[1].spawnKey
                    local pos = spawnPositions[key]
                    if pos then
                        hrp.CFrame = CFrame.new(pos) * CFrame.new(0, 3, 0)
                    else
                        hrp.CFrame = getSpawnCFrame(levelValue.Value)
                    end
                    hrp.Anchored = true
                    hrp.Velocity = Vector3.zero
                    hrp.AssemblyLinearVelocity = Vector3.zero
                else
                    hrp.CFrame = getSpawnCFrame(levelValue.Value)
                    hrp.Anchored = true
                    hrp.Velocity = Vector3.zero
                    hrp.AssemblyLinearVelocity = Vector3.zero
                end

                if now - lastNoTargetNotify >= bossNotifyCooldown then
                    lastNoTargetNotify = now
                    WindUI:Notify({
                        Title = "No Targets Available",
                        Content = "No bosses or mobs are spawned",
                        Duration = 2,
                        Icon = "info",
                    })
                end
            end

            RunService.Heartbeat:Wait()
        end
    end)
    if not success then
        warn("autoPriorityLoop error:", err)
    end

    safelyLand()
    disableNoclip()
    if hrp then
        hrp.Anchored = false
    end
end

