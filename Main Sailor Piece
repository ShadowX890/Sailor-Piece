local function autoFarmLoop()
    local success, err = pcall(function()
        while autoFarmRunning do
            if not hrp then
                local char = player.Character
                if char then
                    hrp = char:FindFirstChild("HumanoidRootPart")
                end
                if not hrp then
                    RunService.Heartbeat:Wait()
                    continue
                end
            end

            if selectedWeapon ~= "" then
                local character = player.Character
                if character then
                    local toolInHand = character:FindFirstChild(selectedWeapon)
                    if not toolInHand then
                        local backpack = player:FindFirstChild("Backpack")
                        if backpack then
                            local tool = backpack:FindFirstChild(selectedWeapon)
                            if tool and tool:IsA("Tool") then
                                tool.Parent = character
                            end
                        end
                    end
                end
            end

            local now = tick()
            local level = levelValue.Value
            local questUI = player.PlayerGui:FindFirstChild("QuestUI")
            local questFrame = questUI and questUI:FindFirstChild("Quest")

            -- 🔁 ตรวจสอบ Observation Haki ถ้าเปิดใช้งาน
            if autoObservationHaki and autoFarmRunning then
                if now >= lastObservationCheck + observationCheckCooldown then
                    local cooldownUI = player.PlayerGui:FindFirstChild("CooldownUI")
                    local inCooldown = false
                    if cooldownUI then
                        local mainFrame = cooldownUI:FindFirstChild("MainFrame")
                        if mainFrame then
                            local obsCooldown = mainFrame:FindFirstChild("Cooldown_ObsHaki_Observation")
                            if obsCooldown then
                                inCooldown = true
                            end
                        end
                    end

                    local dodgeUI = player.PlayerGui:FindFirstChild("DodgeCounterUI")
                    local hakiOn = false
                    if dodgeUI then
                        local mainFrame = dodgeUI:FindFirstChild("MainFrame")
                        if mainFrame and mainFrame.Visible then
                            hakiOn = true
                        end
                    end

                    if not inCooldown and not hakiOn then
                        if now >= lastObservationRemoteTime + minRemoteInterval then
                            local remote = ReplicatedStorage:FindFirstChild("RemoteEvents") and ReplicatedStorage.RemoteEvents:FindFirstChild("ObservationHakiRemote")
                            if remote then
                                pcall(function()
                                    remote:FireServer({ "Toggle" })
                                end)
                                lastObservationRemoteTime = now
                            end
                        end
                    end

                    lastObservationCheck = now
                end
            end

            local currentMode = nil
            for _, mode in ipairs(modes) do
                if level >= mode.min and level <= mode.max then
                    currentMode = mode
                    break
                end
            end

            if not currentMode then
                WindUI:Notify({
                    Title = "⚠️ เลเวลเกิน",
                    Content = "เลเวลของคุณเกิน 10000 แล้ว หยุด Auto Farm",
                    Duration = 5,
                    Icon = "alert-triangle",
                })
                autoFarmRunning = false
                break
            end

            if questFrame then
                local shouldAccept = false
                if not questFrame.Visible then
                    shouldAccept = true
                else
                    if currentMode.questNPC ~= lastAcceptedQuest then
                        shouldAccept = true
                    end
                end

                if shouldAccept and now >= lastQuestCheck + questCheckInterval then
                    acceptQuest(currentMode.questNPC)
                    lastQuestCheck = now
                end
            end

            if questFrame and questFrame.Visible then
                local targetAlive = false
                if currentTarget and currentTarget.Parent == npcFolder then
                    local humanoid = currentTarget:FindFirstChild("Humanoid")
                    local monRoot = currentTarget:FindFirstChild("HumanoidRootPart")
                    if humanoid and humanoid.Health > 0 and monRoot then
                        local valid = false
                        for _, mName in ipairs(currentMode.monsters) do
                            if mName == currentTarget.Name then
                                valid = true
                                break
                            end
                        end
                        if valid then
                            targetAlive = true
                        else
                            currentTarget = nil
                        end
                    else
                        currentTarget = nil
                    end
                end

                if targetAlive then
                    local monRoot = currentTarget:FindFirstChild("HumanoidRootPart")
                    if not monRoot then
                        currentTarget = nil
                        hrp.CFrame = getSpawnCFrame(level)
                        hrp.Anchored = true
                        hrp.Velocity = Vector3.zero
                        hrp.AssemblyLinearVelocity = Vector3.zero
                        RunService.Heartbeat:Wait()
                        continue
                    end
                    local behindPos = monRoot.Position + monRoot.CFrame.LookVector * -attackDistance
                    hrp.CFrame = CFrame.lookAt(behindPos, monRoot.Position)
                    hrp.Anchored = false

                    if now >= lastAttackTime + attackCooldown then
                        requestHit:FireServer()
                        lastAttackTime = now
                    end

                    for skillName, enabled in pairs(skillToggles) do
                        if enabled then
                            local lastTime = lastSkillPressTime[skillName] or 0
                            if now >= lastTime + skillPressCooldown then
                                local keyCode = getKeyCode(skillName)
                                if keyCode then
                                    VirtualInput:SendKeyEvent(true, keyCode, false, game)
                                    task.wait(0.05)
                                    VirtualInput:SendKeyEvent(false, keyCode, false, game)
                                    lastSkillPressTime[skillName] = now
                                end
                            end
                        end
                    end

                else
                    currentTarget = nil
                    for _, monsterName in ipairs(currentMode.monsters) do
                        local monster = npcFolder:FindFirstChild(monsterName)
                        if monster then
                            local humanoid = monster:FindFirstChild("Humanoid")
                            local monRoot = monster:FindFirstChild("HumanoidRootPart")
                            if humanoid and humanoid.Health > 0 and monRoot then
                                currentTarget = monster
                                break
                            end
                        end
                    end

                    if currentTarget then
                        local monRoot = currentTarget:FindFirstChild("HumanoidRootPart")
                        if monRoot then
                            local behindPos = monRoot.Position + monRoot.CFrame.LookVector * -attackDistance
                            hrp.CFrame = CFrame.lookAt(behindPos, monRoot.Position)
                        end
                        hrp.Anchored = false
                    else
                        hrp.CFrame = getSpawnCFrame(level)
                        hrp.Anchored = true
                        hrp.Velocity = Vector3.zero
                        hrp.AssemblyLinearVelocity = Vector3.zero
                    end
                end
            else
                hrp.CFrame = getSpawnCFrame(level)
                currentTarget = nil
                hrp.Anchored = true
                hrp.Velocity = Vector3.zero
                hrp.AssemblyLinearVelocity = Vector3.zero
            end

            RunService.Heartbeat:Wait()
        end
    end)
    if not success then
        warn("autoFarmLoop error:", err)
    end

    safelyLand()
    disableNoclip()
    if hrp then
        hrp.Anchored = false
    end
end

